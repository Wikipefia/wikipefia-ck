# Copy this to .env.local and fill in the values.
# All apps and Convex read from this single file.

# ── Convex client / CLI (filled by `convex dev` on first run) ──
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=

# ── Server-side keys (auto-synced to Convex deployment) ────────
# OpenRouter — for the chat agent to call LLM models.
# https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ── Optional: GitHub App (for /convex/github.ts content sync) ──
# GITHUB_APP_ID=
# GITHUB_APP_INSTALLATION_ID=
# GITHUB_APP_PRIVATE_KEY=""
